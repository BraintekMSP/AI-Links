{
  "contract_name": "schema_reality_contract",
  "contract_version": "0.1.0",
  "function_name": "is_schema_real_or_shadow_copied",
  "purpose": "Determine whether the schema package in a target workspace is real enough to govern work, only partially materialized, copied only, or fully missing.",
  "input_contract": {
    "workspace_root": {
      "type": "absolute_path",
      "required": true,
      "description": "Workspace root to inspect."
    },
    "expected_schema_package": {
      "type": "string",
      "required": true,
      "description": "Expected schema family or package name."
    },
    "startup_surfaces": {
      "type": "string_array",
      "required": false,
      "description": "Optional startup or package surfaces that should align with the schema package."
    }
  },
  "output_contract": {
    "schema_reality_state": {
      "type": "enum",
      "values": [
        "real",
        "partial",
        "copied_only",
        "fully_missing"
      ],
      "description": "Highest-confidence current state for the schema package in the workspace."
    },
    "state_reasons": {
      "type": "map",
      "description": "Reason vocabulary grouped by state so the active result can use bounded explanations.",
      "values": {
        "real": [
          "current_schema_files_present",
          "package_surface_aligned",
          "folder_topology_aligned",
          "startup_discovery_path_real"
        ],
        "partial": [
          "current_schema_files_present_with_missing_surfaces",
          "package_surface_out_of_sync",
          "folder_topology_partial",
          "startup_discovery_path_weakened"
        ],
        "copied_only": [
          "schema_files_present_without_materialization",
          "stale_companion_artifacts",
          "copied_without_package_alignment",
          "folder_topology_mismatch",
          "schema_present_not_governing"
        ],
        "fully_missing": [
          "schema_package_absent",
          "startup_surface_absent",
          "package_surface_absent"
        ]
      }
    },
    "active_reasons": {
      "type": "string_array",
      "description": "Reason list selected from the active state's allowed reason vocabulary."
    },
    "recommended_next_action": {
      "type": "enum",
      "values": [
        "none",
        "run_gov2gov_migration"
      ],
      "description": "Safe next routing action based on the current state."
    },
    "safe_repairs": {
      "type": "string_array",
      "description": "Non-destructive repairs or updates that may be proposed from this state."
    }
  },
  "result_example": {
    "schema_reality_state": "copied_only",
    "active_reasons": [
      "stale_companion_artifacts",
      "copied_without_package_alignment",
      "schema_present_not_governing"
    ],
    "recommended_next_action": "run_gov2gov_migration",
    "safe_repairs": [
      "refresh_package_surface",
      "realign_startup_discovery_paths",
      "update_stale_companion_artifacts"
    ]
  }
}
