<Project>
  <PropertyGroup>
    <AnarchyBrandingVersion>0.1.0</AnarchyBrandingVersion>
    <AnarchyBrandingBrandDisplayName>Anarchy-AI</AnarchyBrandingBrandDisplayName>
    <AnarchyBrandingSetupDisplayName>Anarchy-AI Setup</AnarchyBrandingSetupDisplayName>
    <AnarchyBrandingUserProfileMarketplaceDisplayName>Anarchy-AI User Profile</AnarchyBrandingUserProfileMarketplaceDisplayName>
    <AnarchyBrandingRepoLocalMarketplaceDisplayNameTemplate>Anarchy-AI Repo (&lt;RepoName&gt;)</AnarchyBrandingRepoLocalMarketplaceDisplayNameTemplate>
    <AnarchyBrandingAuthorName>Matt Herring</AnarchyBrandingAuthorName>
    <AnarchyBrandingAuthorUrl>https://github.com/BraintekMSP/AI-Links</AnarchyBrandingAuthorUrl>
    <AnarchyBrandingHomepageUrl>https://github.com/BraintekMSP/AI-Links</AnarchyBrandingHomepageUrl>
    <AnarchyBrandingRepositoryUrl>https://github.com/BraintekMSP/AI-Links</AnarchyBrandingRepositoryUrl>
    <AnarchyBrandingDeveloperName>Matt Herring</AnarchyBrandingDeveloperName>
    <AnarchyBrandingPluginManifestVersion>0.1.9</AnarchyBrandingPluginManifestVersion>
    <AnarchyBrandingPrivacyPolicyUrl>https://github.com/BraintekMSP/AI-Links/blob/main/plugins/anarchy-ai/PRIVACY.md</AnarchyBrandingPrivacyPolicyUrl>
    <AnarchyBrandingTermsOfServiceUrl>https://github.com/BraintekMSP/AI-Links/blob/main/LICENSE</AnarchyBrandingTermsOfServiceUrl>
    <AnarchyBrandingDefaultUpdateSourceZipUrl>https://github.com/BraintekMSP/AI-Links/archive/refs/heads/main.zip</AnarchyBrandingDefaultUpdateSourceZipUrl>
    <AnarchyBrandingBrandColor>#203630</AnarchyBrandingBrandColor>
    <AnarchyBrandingPluginDescription>Windows-first local Anarchy-AI harness that turns incomplete repo context into durable working context for complex changes.</AnarchyBrandingPluginDescription>
    <AnarchyBrandingPluginShortDescription>Turn incomplete context into higher-value working context for complex changes</AnarchyBrandingPluginShortDescription>
    <AnarchyBrandingPluginLongDescription>Installs Anarchy-AI, the runtime harness for the AGENTS Heuristic Underlay. It helps transform incomplete repo context into valuable working context for complex changes, often with lower token consumption than rebuilding that context from scratch in chat. Anarchy-AI preflights complex changes, compiles active work, checks schema reality, and non-destructively migrates current AGENTS files into a directionally stronger structure informed by Google Research on repeated exposure and structured context.</AnarchyBrandingPluginLongDescription>
    <AnarchyBrandingBrandingRootDirectoryRelativePath>branding</AnarchyBrandingBrandingRootDirectoryRelativePath>
    <AnarchyBrandingBrandingAssetsDirectoryRelativePath>branding/assets</AnarchyBrandingBrandingAssetsDirectoryRelativePath>
    <AnarchyBrandingBrandingPublishedMaterialsDirectoryRelativePath>branding/published-materials</AnarchyBrandingBrandingPublishedMaterialsDirectoryRelativePath>
    <AnarchyBrandingBrandingInstructionAdditionsDirectoryRelativePath>branding/published-materials/instruction-additions</AnarchyBrandingBrandingInstructionAdditionsDirectoryRelativePath>
    <AnarchyBrandingBundleBrandingDirectoryRelativePath>branding</AnarchyBrandingBundleBrandingDirectoryRelativePath>
    <AnarchyBrandingBundleBrandingPsd1FileRelativePath>branding/anarchy-branding.generated.psd1</AnarchyBrandingBundleBrandingPsd1FileRelativePath>
    <AnarchyBrandingBundleSetupHeaderImageRelativePath>assets/anarchy-ai.png</AnarchyBrandingBundleSetupHeaderImageRelativePath>
    <AnarchyBrandingBundleSetupIconRelativePath>assets/anarchy-ai.ico</AnarchyBrandingBundleSetupIconRelativePath>
    <AnarchyBrandingBundlePluginComposerIconRelativePath>assets/anarchy-ai.svg</AnarchyBrandingBundlePluginComposerIconRelativePath>
    <AnarchyBrandingBundlePluginLogoRelativePath>assets/anarchy-ai.svg</AnarchyBrandingBundlePluginLogoRelativePath>
  </PropertyGroup>
</Project>
