    <AnarchyBrandingAuthorUrl>https://github.com/BraintekMSP/AI-Links</AnarchyBrandingAuthorUrl>
    <AnarchyBrandingHomepageUrl>https://github.com/BraintekMSP/AI-Links</AnarchyBrandingHomepageUrl>
    <AnarchyBrandingRepositoryUrl>https://github.com/BraintekMSP/AI-Links</AnarchyBrandingRepositoryUrl>
