{
  "contract_name": "harness_gap_state_contract",
  "contract_version": "0.2.1",
  "function_name": "assess_harness_gap_state",
  "purpose": "Assess installation, runtime, schema, startup, and adoption gaps so the harness can report what is missing and what to do next.",
  "input_contract": {
    "workspace_root": {
      "type": "absolute_path",
      "required": true,
      "description": "Workspace root to inspect."
    },
    "host_context": {
      "type": "string",
      "required": false,
      "description": "Optional host context such as codex, claude, cursor, or generic."
    },
    "expected_capabilities": {
      "type": "string_array",
      "required": false,
      "description": "Optional capabilities the current environment expects to have available."
    }
  },
  "output_contract": {
    "workspace_role": {
      "type": "object",
      "description": "Role envelope declaring whether this workspace is schema/plugin source-delivery, a material governance consumer, or mixed/undetermined before adoption claims are interpreted."
    },
    "runtime_provenance": {
      "type": "object",
      "description": "Runtime provenance envelope declaring whether the callable harness came from user profile install, repo-local install, source checkout, or an unknown/external runtime lane."
    },
    "consumer_material_governance_check": {
      "type": "enum",
      "values": [
        "applicable",
        "not_applicable",
        "undetermined"
      ],
      "description": "Whether governed AGENTS materialization checks apply to this workspace role."
    },
    "installation_state": {
      "type": "enum",
      "values": [
        "repo_bootstrapped",
        "user_profile_bootstrapped",
        "repo_bundle_present_unregistered",
        "external_runtime_only"
      ],
      "description": "Current repo/bootstrap state for Anarchy-AI in this workspace."
    },
    "runtime_state": {
      "type": "enum",
      "values": [
        "callable_and_repo_bundled",
        "repo_runtime_missing",
        "callable_external"
      ],
      "description": "Current runtime state for the harness relative to the workspace."
    },
    "schema_state": {
      "type": "object",
      "description": "Condensed schema reality, integrity, and possession summary."
    },
    "underlay_readiness": {
      "type": "object",
      "description": "Non-mutating readiness result that separates portable schema/template availability from actual repo utilization of narrative and governed AGENTS surfaces.",
      "fields": {
        "readiness_state": {
          "type": "enum",
          "values": [
            "portable_underlay_unavailable",
            "portable_underlay_partial",
            "portable_underlay_available_no_repo_utilization",
            "portable_underlay_available_narrative_scaffolded",
            "portable_underlay_utilized"
          ]
        },
        "portable_schema_state": {
          "type": "enum",
          "values": [
            "missing",
            "partial",
            "complete"
          ]
        },
        "missing_portable_schema_files": {
          "type": "string_array"
        },
        "narrative_schema_available": {
          "type": "boolean"
        },
        "narrative_templates_available": {
          "type": "boolean"
        },
        "missing_narrative_templates": {
          "type": "string_array"
        },
        "narrative_register_present": {
          "type": "boolean"
        },
        "narrative_register_valid": {
          "type": "boolean"
        },
        "narrative_projects_directory_present": {
          "type": "boolean"
        },
        "narrative_record_count": {
          "type": "integer"
        },
        "governed_agents_family_present": {
          "type": "boolean"
        },
        "repo_utilization_state": {
          "type": "enum",
          "values": [
            "none",
            "narrative_scaffolded_no_records",
            "narrative_records_present",
            "governed_agents_family_present"
          ]
        },
        "observed_surfaces": {
          "type": "string_array"
        },
        "utilization_gaps": {
          "type": "string_array"
        },
        "safe_repairs": {
          "type": "string_array"
        },
        "agent_actions": {
          "type": "string_array"
        }
      }
    },
    "artifact_hygiene": {
      "type": "object",
      "description": "Non-destructive scan result for repo-local generated artifact directories, with relocation-oriented safe repairs rather than deletion guidance.",
      "fields": {
        "artifact_hygiene_state": {
          "type": "enum",
          "values": [
            "clean",
            "repo_local_artifacts_observed",
            "not_checked"
          ]
        },
        "observed_artifact_paths": {
          "type": "string_array",
          "description": "Repo-relative generated artifact directories observed under the workspace root."
        },
        "recommended_artifact_lanes": {
          "type": "string_array",
          "description": "Preferred OS-local lanes for build/cache/runtime/scratch output."
        },
        "safe_repairs": {
          "type": "string_array",
          "description": "Relocation-oriented repair suggestions; this assessment does not delete anything."
        }
      }
    },
    "adoption_state": {
      "type": "enum",
      "values": [
        "fully_adopted",
        "partially_adopted",
        "bootstrap_required",
        "adapter_gap_present"
      ],
      "description": "Overall adoption state for the harness in this workspace and host context."
    },
    "missing_components": {
      "type": "string_array",
      "description": "Missing or unresolved environment pieces preventing full adoption."
    },
    "safe_repairs": {
      "type": "string_array",
      "description": "Safe repair or completion moves suggested from the current state."
    },
    "admin_actions": {
      "type": "string_array",
      "description": "Actions intended for a human operator or bootstrap lane."
    },
    "agent_actions": {
      "type": "string_array",
      "description": "Actions the agent can take next without redefining the harness."
    },
    "evidence_basis": {
      "type": "string_array",
      "description": "What the assessment used to ground the result."
    },
    "paths": {
      "type": "object",
      "description": "Nested path evidence using `origin`, `source`, and `destination` roles rather than flat path fields."
    }
  },
  "result_example": {
    "workspace_role": {
      "machine_key": "schema_authoring_and_plugin_delivery_workspace",
      "statement": "This workspace deliberately combines schema/harness development with plugin delivery in one source repo.",
      "evidence": [
        "root_portable_schema_family_present"
      ],
      "claim_scope_effect": [
        "consumer_material_governance_check:not_applicable_unless_explicitly_requested"
      ],
      "confidence": "inferred_from_workspace"
    },
    "runtime_provenance": {
      "machine_key": "user_profile_installed_runtime",
      "statement": "This callable harness is running from the current user's installed plugin bundle. It is convenient and valid as an installed runtime, but it is not source truth for the workspace being evaluated."
    },
    "consumer_material_governance_check": "not_applicable",
    "installation_state": "repo_bundle_present_unregistered",
    "runtime_state": "callable_and_repo_bundled",
    "schema_state": {
      "schema_reality_state": "copied_only",
      "integrity_state": "aligned",
      "possession_state": "unpossessed",
      "active_reasons": [
        "schema_present_not_governing"
      ]
    },
    "underlay_readiness": {
      "readiness_state": "portable_underlay_available_no_repo_utilization",
      "portable_schema_state": "complete",
      "missing_portable_schema_files": [],
      "narrative_schema_available": true,
      "narrative_templates_available": true,
      "missing_narrative_templates": [],
      "narrative_register_present": false,
      "narrative_register_valid": false,
      "narrative_projects_directory_present": false,
      "narrative_record_count": 0,
      "governed_agents_family_present": false,
      "repo_utilization_state": "none",
      "observed_surfaces": [
        "portable_schema:AGENTS-schema-narrative.json"
      ],
      "utilization_gaps": [
        "narrative_register_missing:.agents/anarchy-ai/narratives/register.json",
        "narrative_records_absent"
      ],
      "safe_repairs": [
        "seed_narrative_register_and_projects_from_underlay"
      ],
      "agent_actions": [
        "inspect_underlay_readiness_before_declaring_adoption",
        "do_not_treat_schema_availability_as_repo_utilization"
      ]
    },
    "adoption_state": "partially_adopted",
    "artifact_hygiene": {
      "artifact_hygiene_state": "repo_local_artifacts_observed",
      "observed_artifact_paths": [
        "harness/server/dotnet/bin",
        "harness/server/dotnet/obj"
      ],
      "recommended_artifact_lanes": [
        "%LOCALAPPDATA%\\Anarchy-AI\\<repo>\\",
        "${XDG_CACHE_HOME:-~/.cache}/anarchy-ai/<repo>/",
        "~/Library/Caches/Anarchy-AI/<repo>/"
      ],
      "safe_repairs": [
        "relocate_generated_artifacts_to_machine_local_cache",
        "inventory_and_quarantine_before_delete_never_delete_from_hygiene_assessment"
      ]
    },
    "missing_components": [
      "marketplace_missing",
      "codex_skill_surface_missing"
    ],
    "safe_repairs": [
      "run_repo_bootstrap_script"
    ],
    "admin_actions": [
      "run_bootstrap_harness_install"
    ],
    "agent_actions": [
      "run_preflight_session_before_complex_changes",
      "treat_schema_state_as_input_not_completion"
    ],
    "evidence_basis": [
      "repo_plugin_surfaces",
      "marketplace_registration",
      "schema_reality_inspection"
    ],
    "paths": {
      "source": {
        "root_path": "C:\\path\\to\\workspace\\plugins\\anarchy-ai",
        "files": {
          "runtime_executable_file_path": "C:\\path\\to\\workspace\\plugins\\anarchy-ai\\<bundle-runtime-executable-file>"
        },
        "relative": {
          "runtime_executable_file_relative_path": "<bundle-runtime-executable-relative-path>"
        }
      },
      "destination": {
        "root_path": "C:\\path\\to\\workspace",
        "files": {
          "marketplace_file_path": "C:\\path\\to\\workspace\\<marketplace-file>"
        },
        "relative": {
          "marketplace_file_relative_path": "<marketplace-file-relative-path>"
        }
      }
    }
  }
}
